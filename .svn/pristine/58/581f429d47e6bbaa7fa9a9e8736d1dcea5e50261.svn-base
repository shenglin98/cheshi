        font-size: 14px;
        div {
          margin: 5px 0;
        }
      }
    }
  }
  .mainbody {
    height: 100%;
    background-color: #fff;
    border-radius: 5px;

    .top_box {
      //   height: 45px;
      box-sizing: border-box;
      padding-left: 10px;

      .title {
        display: flex;
        align-items: center;
        height: 30px;
        font-size: 16px;
        font-weight: 600;
      }
      .link_box {
        display: flex;
        // margin-top: 10px;
        box-sizing: border-box;
        padding-right: 10px;
        .link_item {
          text-align: center;
          flex: 1;
          .link_icon {
            width: 42px;
            height: 42px;
          }
          .text {
            margin-top: 4px;
          }
        }
      }
    }
    .commonBox {
      font-size: 14px;
      .title {
        font-size: 16px;
        font-weight: bold;
        padding: 10px 0 0 10px;
      }
      .listOfUsersBox {
        padding-left: 10px;
        display: flex;
        overflow: hidden;
        li {
          padding: 10px;
        }
      }
    }
    .content {
      box-sizing: border-box;
      padding: 10px;
      .title {
        display: flex;
        align-items: center;
        height: 30px;
        font-size: 16px;
        font-weight: 600;
      }
      .table_box {
        height: 240px;
        .el-table {
          //   height: 100%;
        }
      }
      .table_mess {
        margin-top: 12px;
        box-sizing: border-box;
        padding: 10px;
        display: flex;
        color: #000;
        font-size: 14px;
        // justify-content: space-between;
        > div {
          width: 32%;
          text-align: center;
        }
      }
    }
    .btn_bom {
      width: 100%;
      text-align: center;
      .van-button {
        width: 70%;
      }
    }
  }
}
</style>