      padding: 18px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      .title {
        font-size: 24px;
        font-weight: 600;
        color: #27a7e0;
        height: 30px;
        text-align: center;
      }
      .s_title {
        font-size: 14px;
        color: #000;
        text-align: center;
      }
      .el-input {
        margin: 12px 0;
      }
