.unitInfo {
  height: calc(100vh - 94px);
  background-color: #f2f2f2;
  box-sizing: border-box;
  padding: 5px;
  .mainbody::-webkit-scrollbar {
    display: none;
  }
  .mainbody {
    height: 100%;
    box-sizing: border-box;
    padding-bottom: 40px;
    // background-color: #fff;
    // border-radius: 5px;
    overflow-y: auto;
    .title_b {
      height: 38px;
      font-size: 16px;
      font-weight: 600;
      display: flex;
      justify-content: center;
      align-items: center;
      .title_text {
        width: 90px;
        height: 28px;
        display: flex;
        justify-content: center;
        align-items: center;
        background: #f2f2f2;
        border-radius: 20px;
      }
    }
    .unit_mess,
    .person_mess,
    .tips_mess {
      box-sizing: border-box;
      padding: 10px;
      background-color: #fff;
      border-radius: 5px;
    }
    .bottom_btn {
      margin-top: 12px;
      text-align: center;
      .van-button {
        width: 80%;
      }
    }
    .person_mess {
      margin-top: 12px;
    }
    .tips_mess {
      margin-top: 12px;
      .content_tips {
        font-size: 14px;
      }
    }
  }
}
</style>
<style lang="scss">
.unitInfo {
  .mainbody {
    .unit_mess,
    .person_mess {
      .van-cell-group {
        .van-cell {
          .van-cell__title {
            flex: unset;
            width: 23% !important;
            font-weight: 600;
          }
          .van-cell__value {
            flex: unset;
            width: 75% !important;
          }
        }
      }
    }
