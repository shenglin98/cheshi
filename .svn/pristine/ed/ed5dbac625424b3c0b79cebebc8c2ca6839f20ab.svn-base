    padding-left: 10px;
  }
  .list_content {
    height: calc(100vh - 183px);
    background-color: #fff;
    .van-pull-refresh {
      height: 100%;
      width: 100%;
      overflow-y: auto;

      .van-list {
        // height: 100%;
        // width: 100%;
        // overflow-y: auto;
      }
      .list_item {
        height: 100px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #e3e3e3;
        margin: 0 10px;
        .item_left {
          display: flex;
          font-size: 14px;
          font-weight: 600;
          max-width: 80%;
          .van-image {
            width: 80px;
            height: 80px;
            > img {
              width: 100%;
              height: 100%;
            }
          }
          .item_text_box {
            margin: 8px 0 0 10px;
            .item_price {
              color: red;
              margin-top: 10px;
            }
          }
        }
        .item_right {
          height: 73px;
          .item_text_box {
            margin: 8px 0 0 10px;
