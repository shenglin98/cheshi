            color: #ababab;
            .item_num {
              color: red;
              margin-top: 10px;
            }
          }
        }
      }
    }
  }
  .content {
    height: 80vh;
    padding: 16px 16px;
    .btn_box {
      margin-top: 40px;
      text-align: center;
      .van-button {
        width: 100px;
        margin-left: 12px;
      }
    }
    .crowd_box {
      .btn_group {
        .van-button {
          margin-left: 8px;
          margin-top: 10px;
        }
      }
    }
    .btn_bgc {
      background-color: #f2f2f2;
    }
    .sex_box {
      margin-top: 10px;
