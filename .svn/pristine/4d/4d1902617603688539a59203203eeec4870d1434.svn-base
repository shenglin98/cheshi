                margin-top: 10px;
              }
            }
          }
          .item_right {
            .item_text_box {
              margin: 8px 0 0 10px;
              font-size: 14px;
              font-weight: 600;
              text-align: right;
              color: #ababab;
              .item_num {
                color: red;
                margin-top: 10px;
              }
            }
          }
        }
      }
    }
    .van-popup {
      .content {
        width: 100%;
