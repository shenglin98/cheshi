            min-height: 35px;
            word-wrap: break-word;
            word-break: break-all;
            font-size: 14px;
          }
        }
      }
    }
    .btn_box {
      width: 100%;
      display: flex;
      justify-content: space-around;
      .van-button {
        width: 35%;
      }
    }
  }
}
</style>