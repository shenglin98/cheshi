        box-sizing: border-box;
        padding: 10px;
      }
    }
    .title_b {
      height: 38px;
      font-size: 16px;
      font-weight: 600;
      display: flex;
      justify-content: center;
      align-items: center;
      .title_text {
        width: 90px;
        height: 28px;
        display: flex;
        justify-content: center;
        align-items: center;
        background: #f2f2f2;
        border-radius: 20px;
      }
    }
    .content_list {
      height: 72%;
      overflow-y: auto;
      .content_item {
        margin-top: 10px;
        .citem_title {
          width: 100%;
