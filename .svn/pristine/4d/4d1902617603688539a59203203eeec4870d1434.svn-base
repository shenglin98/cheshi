          display: flex;
          justify-content: center;
          align-items: center;
          font-size: 16px;
          font-weight: 600;
          background-color: #d7d5d5;
        }
        .citem_box {
          width: 100%;
          display: flex;
          background-color: #f2f2f2;
          .remark,
          .remind {
            // width: 50% !important;
