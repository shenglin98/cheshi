            // if (window.navigator && window.navigator.msSaveOrOpenBlob) {
            //   // For Edge
            //   window.navigator.msSaveOrOpenBlob(pdfBlob);
            // } else {
            //   // For other browsers
            //   const url = URL.createObjectURL(pdfBlob);
            //   const link = document.createElement("a");
            //   link.href = url;
            //   // link.download = "file.pdf"; // 下载文件的默认文件名
