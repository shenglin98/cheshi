    //   // console.log('查询报告返回的数据',data.data[0].base64String);
    //   this.viewPdf(data.data[0].base64String)
    // },

    // //content是base64格式
    // viewPdf(content) {
    //   // console.log(  this.GLOBAL.names,'mmmmmmmmmmmmm');
    //   // console.log("content",content)
    //   const blob = this.base64ToBlob(content)
