<template>
  <div class="header">
    <header class="head">
      <div @click="back()"><i v-if="show" class="el-icon-back"></i></div>
      <div>{{ showTitle || this.GLOBAL.colorList }}</div>
      <div class="ddd">
        <div
          class="fan"
          v-if="$route.name == 'orderMessage'"
          @click="View_report"
        >
          查看报告
        </div>
        <!-- <div
          class="fan"
          v-if="$route.name == 'viewReport'"
          @click="handledownloadReport"
        >
          下载PDF
        </div> -->
        <!-- <div class="fan" v-if="this.GLOBAL.colorList == '体检结果'">
          查看报告
        </div> -->
      </div>

