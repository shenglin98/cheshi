    //     window.navigator.msSaveOrOpenBlob(blob)
    //   } else {
    //     const fileURL = URL.createObjectURL(blob);
    //     console.log(fileURL, '要下载的地址以及文件aaa');
    //     window.open(fileURL);//弹出ppf文件
