    //     uInt8Array[i] = raw.charCodeAt(i)
    //   }
    //   // return new Blob([uInt8Array], { type: 'application/pdf' })
    //   let url = window.URL.createObjectURL(new Blob([uInt8Array], { type: 'application/pdf' }))
    //   console.log(url, '要下载的地址以及文件bbb');
    //   const a = document.createElement("a");
    //   a.href = url;
    //   a.download = `${this.GLOBAL.codes}-${this.GLOBAL.names}`;//下载文件regid以及文件名字
    //   document.body.appendChild(a);
    //   a.click();
    //   URL.revokeObjectURL(a.href);//URL.revokeObjectURL() 静态方法用来释放一个之前已经存在的
    //   document.body.removeChild(a);//删除节点
