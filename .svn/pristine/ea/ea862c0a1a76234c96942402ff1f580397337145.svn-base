        // 点击确定遮罩层消失
        determine() {
            this.query = false;
        },
        // 跳转到在线咨询
        jumpConsult() {
            if (!this.operatorcode) {
                this.$toast.fail("当前人员未建档,请传入当前操作人编码!")
                this.$router.push("/login");
                return false;
            }
            this.$router.push('/consult')
        },
        // 跳转到体检定制
        jumpCustomized() {
            if (!this.operatorcode) {
                this.$toast.fail("当前人员未建档,请传入当前操作人编码!")
                this.$router.push("/login");
                return false;
            } 
            this.$router.push('/customized')
        },
        // 跳转到医院简介
        jumpSynopsis(flag) {
            if (!this.operatorcode) {
                this.$toast.fail("当前人员未建档,请传入当前操作人编码!")
                this.$router.push("/login");
                return false;
            }
            this.$router.push('/synopsis')
        },
        // 跳转到预约界面
