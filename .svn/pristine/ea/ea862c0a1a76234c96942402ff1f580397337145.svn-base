            // downa.download = `${this.GLOBAL.codes}-${this.GLOBAL.names}`; // 下载文件名
            // document.body.appendChild(downa);
            // downa.click(); // 模拟点击A标签
            // document.body.removeChild(downa); // 下载完成移除元素
            // window.URL.revokeObjectURL(href); // 释放blob对象
        },
