            this.$router.push('/personalMedical')
        },
        // 跳转到预约界面
        jumpReservation(flag) {
            if (!this.operatorcode) {
                this.$toast.fail("当前人员未建档,请传入当前操作人编码!")
                this.$router.push("/login");
                return false;
            }
            // 设置体检类型 personalflag: 0, // 0-个人  1-单位 funcstatus
            localStorage.setItem('personalflag', 0)
            this.$router.push('/reservation')
        },
        // 跳转到团检
        jumpGroupsCheck(flag) {
            if (!this.operatorcode) {
                this.$toast.fail("当前人员未建档,请传入当前操作人编码!")
                this.$router.push("/login");
                return false;
            } 
            // 设置体检类型 personalflag: 0, // 0-个人  1-单位
            localStorage.setItem('personalflag', 1)
            this.$router.push('/unitReserva')
        },
        // 跳转到导诊
        jumpGroupsGuidance(flag) {
            if (!this.operatorcode) {
                this.$toast.fail("当前人员未建档,请传入当前操作人编码!")
                this.$router.push("/login");
                return false;
            }
            // 设置体检类型 personalflag: 0, // 0-个人  1-单位
            // localStorage.setItem('personalflag', 1)
            this.$router.push({
                path: `/report`,
                query: {
                    'page': 'guidance'
                }
            })
            // this.$router.push('/guidance')
        },
        // 体检推荐
        jumpGroupsRecommend(flag) {
            this.$toast.fail("未配置健康问卷字典!");
        },
        // 跳转集合回调
        handleButtonAll(codeindex) {
            switch (codeindex) {
                case '1':
                    this.jumpReservation()
                    break;
                case '2':
                    this.jumpReservation()
                    break;
                case '3':
                    this.jumpReportQuery()
                    break;
                case '4':
                    this.jumpGroupsCheck()
                    break;
                case '5':
                    this.jumpGroupsGuidance()
                    break;
                case '6':
                    this.jumpConsult()
                    break;
                case '7':
                    this.jumpSynopsis()
                    break;
                // case '8':
                //     break;
                case '9':
                    this.jumpCustomized();
                    break;
                default:
                    break;
            }
        },
