    beforeDestroy() {

    },
    watch: {
        $route: {
            handler: function (val, oldVal) {
                // this.getMyToken()
                this.showTitle = val.meta.title;
                if (this.$route.path == "/index") {
                    this.show = false;
                } else {
                    this.show = true;
                }
