              </template>
              <template #right-icon>
                <van-radio name="wechatPay" />
              </template>
            </van-cell>
          </van-cell-group>
        </van-radio-group> -->
      </van-form>
      <!-- 底部支付信息 -->
      <div class="footer">
        <div class="footer_text">
          <!-- <div class="f_text">微信支付</div>
          <div class="f_price">￥{{ personPrice || 0.0 }}</div> -->
