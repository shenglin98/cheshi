      </van-popup>
      <!-- 选择体检人弹框 -->
      <van-popup
        v-model="showQuestionnaire"
        class="questionnaire_popup"
        :close-on-click-overlay="false"
        position="bottom"
        :style="{ height: '95%' }"
      >
        <div class="btnClose">
          <van-icon @click="handlePopupClose" name="cross" class="iconClos" />
          <!-- icon="cross"  -->
          <!-- <van-button
            plain
            hairline
            size="small"
            type="default"
            @touchstart="handlePopupClose"
            >关 闭</van-button
          > -->
        </div>
        <div class="questionnaire_content">
          <!-- 内容 -->
          <div class="life_habit">
            <!-- 问卷题目 -->
            <!-- 一级标题questionnairelist -->
            <div
              class="Questionnaire"
              v-for="(k, index) in questionnairelist"
              :key="index"
            >
              <div class="life_habit_title">
                <h2>{{ k.itemname }}</h2>
              </div>
              <div class="life_habit_content">
                <!-- 二级标题questionnaireitems -->
                <div
                  class="basic_information"
                  v-for="item in k.questionnaireitems"
                  :key="item.itemcode"
                >
                  <div class="two_topic" style="display: block">
                    <!-- 题目 -->
                    <span
                      :style="{
                        color: item.fillFlag == 1 ? 'red' : '',
                        display: 'block',
                      }"
                      >{{ item.itemname }}</span
                    >
                    <!-- 二级选项optionitems -->
                    <div
                      class="two_options"
                      v-for="(value, index) in item.optionitems"
                      :key="index"
                    >
                      <span v-if="value.inputtype === -1">
                        <template
                          v-for="(val, index) in value.content
                            .split('|X|')
                            .filter((v) => v)"
                        >
                          <myInput
                            :suffix="val"
                            :disabled="item.editstatus == 1"
                            :count="
                              value.content.split('|X|').filter((v) => v).length
                            "
                            :item="item"
                            @updateValue="handleUpdate"
                            :value.sync="value.remark"
                            :index="index"
                            :key="val"
                          />
                        </template>
                      </span>
                      <van-radio-group
                        style="width: 100%"
                        v-model="item.selectvalue"
                        :disabled="item.editstatus == 1"
                      >
                        <van-radio
                          v-if="[0, 3].indexOf(value.inputtype) !== -1"
                          :name="value.selectvalue"
                          @click="handleRadioChange(item)"
                          style="margin-right: 5px; white-space: normal"
                          :class="
                            value.content.indexOf('|X|') !== -1
                              ? 'radiobox'
                              : ''
                          "
                        >
                          <span
                            style="width: 100%; display: flex; flex-wrap: wrap"
                            v-if="value.content.indexOf('|X|') !== -1"
                          >
                            <template
                              v-for="(val, index) in value.content.split(',')"
                            >
                              <myInput
                                :content="val"
                                :disabled="val.editstatus == 1"
                                :draggable="
                                  value.selectvalue != item.selectvalue
                                "
                                :count="value.content.split(',').length"
                                :value.sync="value.remark"
                                :index="index"
                                :key="val"
                              />
                            </template>
                          </span>
                          <span style="width: 100%" v-else>
                            {{ value.content }}
                            <el-input
                              v-if="[1, 3, 4].indexOf(value.inputtype) !== -1"
                              size="mini"
                              :disabled="value.content != item.selectvalue"
                              v-model="value.remark"
                              :placeholder="value.content"
                              style="width: 4rem"
                            ></el-input>
                          </span>
                        </van-radio>
                      </van-radio-group>
                      <van-checkbox
                        v-if="[2, 4].indexOf(value.inputtype) !== -1"
                        v-model="value.flag"
                        shape="square"
                        :name="value.content"
                        @change="handlechecBox(item, 1)"
                        :true-label="1"
                        style="white-space: normal"
                        :false-label="0"
                        ><span style="white-space: normal">{{
                          value.content
                        }}</span>
                      </van-checkbox>
                    </div>
                    <el-input
                      v-if="[1, 3, 4].indexOf(item.inputtype) !== -1"
                      size="mini"
                      :disabled="item.editstatus == 1"
                      v-model="item.remark"
                      placeholder="请输入"
                      @input="handleInput(item)"
                      style="width: 4rem"
                    ></el-input>
                  </div>
                  <!-- 三级标题questionnaireitems -->
                  <div
                    class="three_topic"
                    v-for="item in item.questionnaireitems"
                    :key="item.itemcode"
                  >
                    <span
                      class="spanClas"
                      v-if="item.itemname.indexOf('|X|') !== -1"
                    >
                      <template
                        v-for="(val, index) in item.itemname.split(',')"
                      >
                        <myInput
                          :content="val"
                          :count="item.itemname.split(',').length"
                          :value.sync="item.remark"
                          :index="index"
                          :item="item"
                          @updateValue="handleValue"
                          :key="val"
                        />
                      </template>
                    </span>
                    <span class="spanClas" v-else>
                      {{ item.itemname }}
                    </span>
                    <!-- 三级选项optionitems -->
                    <div class="three_content">
                      <div
                        class="three_options"
                        v-for="(Opitem, index) in item.optionitems"
                        :key="index"
                      >
                        <span v-if="[-1].indexOf(Opitem.inputtype) !== -1">
                          <span v-if="Opitem.content.indexOf('|X|') !== -1">
                            <template
                              v-for="(val, index) in Opitem.content.split(',')"
                            >
                              <myInput
                                :content="val"
                                :count="Opitem.content.split(',').length"
                                :value.sync="Opitem.remark"
                                :index="index"
                                :item="item"
                                @updateValue="handleValue"
                                :key="val"
                              />
                            </template>
                          </span>
                        </span>
                        <van-radio-group
                          v-model="item.selectvalue"
                          v-if="[0, 3].indexOf(Opitem.inputtype) !== -1"
                        >
                          <van-radio
                            :name="Opitem.content"
                            @click="handleRadioChange(item)"
                            style="
                              margin-right: 5px;
                              white-space: normal !important;
                            "
                          >
                            <span v-if="Opitem.content.indexOf('|X|') !== -1">
                              <template
                                v-for="(val, index) in Opitem.content.split(
                                  ','
                                )"
                              >
                                <myInput
                                  :content="val"
                                  :count="Opitem.content.split(',').length"
                                  :value.sync="Opitem.remark"
                                  :index="index"
                                  :key="val"
                                />
                              </template>
                            </span>
                            <span v-else> {{ Opitem.content }}</span>
                          </van-radio>
                        </van-radio-group>
                        <van-checkbox
                          :name="Opitem.hoyname"
                          v-if="[2, 4].indexOf(Opitem.inputtype) !== -1"
                          v-model="Opitem.flag"
                          shape="square"
                          @change="handlechecBox(item, 2)"
                          :true-label="1"
                          :false-label="0"
                        >
                          <span v-if="Opitem.content.indexOf('|X|') !== -1">
                            <template
                              v-for="(val, index) in Opitem.content.split(',')"
                            >
                              <myInput
                                :content="val"
                                :disabled="Opitem.flag == 0 ? true : false"
                                :count="Opitem.content.split(',').length"
                                :value.sync="Opitem.remark"
                                :index="index"
                                :key="val"
                              />
                            </template>
                          </span>
                          <span v-else> {{ Opitem.content }}</span>
                        </van-checkbox>

                        <el-input
                          v-if="[1].indexOf(Opitem.inputtype) !== -1"
                          size="mini"
                          v-model="Opitem.remark"
                          @input="handleValue('', item)"
                          style="width: 4rem"
                        ></el-input>
                        <el-input
                          v-if="[3, 4].indexOf(Opitem.inputtype) !== -1"
                          :disabled="Opitem.flag == 0"
                          size="mini"
                          v-model="Opitem.remark"
                          @input="handleValue('', item)"
                          style="width: 4rem"
                        ></el-input>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </van-popup>
