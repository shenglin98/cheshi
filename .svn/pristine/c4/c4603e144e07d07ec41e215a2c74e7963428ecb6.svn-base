          align-items: center;
          display: flex;
          .btn {
            .van-button {
              width: 80px;
            }
          }
          .content {
            font-size: 16px;
          }
          .title {
            display: flex;
            align-items: center;
            .date_img {
              width: 20px;
              height: 20px;
            }
            .text {
              font-size: 16px;
              font-weight: 600;
              color: #000;
              margin-left: 10px;
            }
          }
        }
      }
      .courtyardarea {
        height: 60px;
        border-bottom: 1px solid #efefef;
        box-sizing: border-box;
        padding: 0 16px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        .courtyardarea_text {
          font-size: 16px;
          font-weight: 600;
        }
        .setmeal_text {
          margin-top: 2px;
          font-size: 16px;
          color: #7c8586;
        }
      }
      .meetprice {
        height: 40px;
        border-bottom: 1px solid #efefef;
        box-sizing: border-box;
        padding: 0 16px;
        font-size: 16px;
        color: #000;
        display: flex;
        align-items: center;
        justify-content: space-between;
        .title {
          font-weight: 600;
        }
        .price {
        }
      }
      .actualprice {
        height: 40px;
        border-bottom: 1px solid #efefef;
        box-sizing: border-box;
        padding: 0 16px;
        font-size: 16px;
        color: #000;
        display: flex;
        align-items: center;
