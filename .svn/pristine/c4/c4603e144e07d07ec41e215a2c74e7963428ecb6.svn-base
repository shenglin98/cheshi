  </div>
</template>
<script>
import {
  getListData,
  timeStatic,
  TimeStaticForPerson,
  addCustomerOrder,
  saveAppoint,
  healthCheckForH5Post,
  questionnaire,
  Sys_QuestionnaireForH5_ShowCode,
  CheckQuestionMustInput,
} from "@/api/reservation.js";
import myInput from "./input";
export default {
  name: "",

  components: {
    myInput,
  },

  data() {
    return {
      pageForm: {
        name: "",
        sex: 0,
        birthday: "",
        marriage: "",
        telephone: "",
        idcard: "",
        idtype: "01",
        idcardcn: "身份证",
        hiscode: "",
        healthcard: "",
        transport: "",
      },
      loading: false,
      payment: "wechatPay",
      showPicker: false,
      relWkibedat: new Date("2000/01/01"),
      minDate: new Date(1900, 0, 1),
      maxDate: new Date(
        new Date(+new Date() + 8 * 3600 * 1000)
          .toJSON()
          .substr(0, 10)
          .replace("T", " ")
      ),
      dateUrl: require("@/assets/images/date.png"),
      wechatUrl: require("@/assets/images/wechat.png"),
      EditOrderid: "",
      showPerson: false,
      showPelsDate: false,
      showPelsidtype: false,
      choosePerson: "",
      isReserv: false,
      calendarData: [],
      chooseDate: "",
      chooseTimes: "",
      chooseDateTitle: "",
      setmealcode: "",
      combineitems: [],
      setmealObj: {},
      personalflag: "", // 0-个人  1-单位
      operatorcode: "",
      idtypeItems: [
        "身份证",
        "居民户口簿",
        "护照",
        "军官证",
        "驾驶证",
        "港澳居民来往内地通行证",
        "台湾居民来往内地通行证",
      ],
      userData: "",
      checkUserId: "",
      checkPrice: 0,
      personPrice: 0,
      quota: 0,
      totalPrice: 0,
      setcompanymodel: 0,
      showQuestionnaire: false,
      questionnairelist: [], // 问卷
      sexradio: [],
      // idtypeItems: [
      //   {
      //     code: "01",
      //     name: "身份证",
      //   },
      //   {
      //     code: "02",
      //     name: "居民户口簿",
      //   },
      //   {
      //     code: "03",
      //     name: "护照",
      //   },
      //   {
      //     code: "04",
      //     name: "军官证",
      //   },
      //   {
      //     code: "05",
      //     name: "驾驶证",
      //   },
      //   {
      //     code: "06",
      //     name: "港澳居民来往内地通行证",
      //   },
      //   {
      //     code: "07",
      //     name: "台湾居民来往内地通行证",
      //   },
      // ], // 证件类型
      questionCode: "",
      fillOutFlag: false, // 是否填完成
      questionnaireFlag: true, // 是个否可见调查问卷
    };
  },

  computed: {
    totalprice() {
      let price = +this.setmealObj.setmealprice;
      this.combineitems.forEach((k) => {
        price += +k.price;
      });
      return +price.toFixed(3);
    },
    // 实付金额
    realityprice() {
      let price = 0;
      if (this.personalflag == 0) {
        this.combineitems.forEach((k) => {
          price += +k.price;
        });
        return +(+price + +this.setmealObj.setmealprice).toFixed(3);
      } else {
        if (this.setmealObj.grouptype == -1 || this.setmealObj.grouptype == 1) {
          if (this.setmealObj.addsettlementtype == 0) {
            return +price.toFixed(3);
          } else {
            this.combineitems.forEach((k) => {
              price += +k.price;
            });
            return +(+price + +this.setmealObj.setmealprice).toFixed(3);
          }
        } else if (this.setmealObj.grouptype == 2) {
          this.combineitems.forEach((k) => {
            price += +k.price;
          });
          let rprice = +(
            +price +
            +this.setmealObj.setmealprice -
            +this.setmealObj.quota
          ).toFixed(3);
          return rprice > 0 ? rprice : 0;
        }
      }
    },
  },

  mounted() {
    this.operatorcode = localStorage.getItem("operatorcode") || "";
    if (!this.operatorcode) {
      this.$router.push("/login");
      return false;
    }
    let data = this.$route.query || undefined;
    if (!data) {
      this.$router.push("/projectConfirm");
      return;
    }
    this.personalflag = localStorage.getItem("personalflag") || "";
    this.EditOrderid = localStorage.getItem("EditOrderid") || "";
    this.combineitems = JSON.parse(decodeURIComponent(data.combineitems));
    this.checkUserId = this.$route.query.checkUser || "";
    this.checkUserId && this.handleGetUserList();
    let delComCode = JSON.parse(localStorage.getItem("delComCode")) || [];
    if (this.personalflag == 0) {
      this.setmealcode = data.setmealcode;
      getListData({
        businesstype: "SetmealDetail",
        code: this.setmealcode,
      }).then((res) => {
        let data = res.data.result;
        this.setmealObj = data;
        for (let i = 0; i < delComCode.length; i++) {
          let index = this.setmealObj.combineitems.findIndex(
            (k) => k.combinecode === delComCode[i]
          );
          index > -1 && this.setmealObj.combineitems.splice(index, 1);
        }
      });
    } else {
      this.setmealObj = JSON.parse(localStorage.getItem("setmealInfo")) || "";
      this.userData = JSON.parse(localStorage.getItem("companyUserInfo")) || "";
      this.pageForm = {
        name: this.userData.name,
        sex: this.userData.sex,
        birthday: this.userData.birthday,
        marriage: this.userData.marriage,
        telephone: this.userData.telephone,
        hiscode: this.userData.hiscode,
        healthcard: this.userData.healthcard,
        idcard: this.userData.idcard,
        idtype: this.userData.idtype || "01",
        idcardcn: "",
        transport: "",
      };
      switch (this.userData.idtype || "01") {
        case "01":
          this.pageForm.idcardcn = "身份证";
          break;
        case "02":
          this.pageForm.idcardcn = "居民户口簿";
          break;
        case "03":
          this.pageForm.idcardcn = "护照";
          break;
        case "04":
          this.pageForm.idcardcn = "军官证";
          break;
        case "05":
          this.pageForm.idcardcn = "驾驶证";
          break;
        case "06":
          this.pageForm.idcardcn = "港澳居民来往内地通行证";
          break;
        case "07":
          this.pageForm.idcardcn = "台湾居民来往内地通行证";
          break;
        default:
          break;
      }
      for (let i = 0; i < delComCode.length; i++) {
        let index = this.setmealObj.combineitems.findIndex(
          (k) => k.combinecode === delComCode[i]
        );
        index > -1 && this.setmealObj.combineitems.splice(index, 1);
      }
    }
    this.handleGetPriceItems();
    this.handleShowQ();
  },

  methods: {
    // 失焦校验身份证
    handleCheckIdcard() {
      let idCardReg =
        /^(^[1-9]\d{7}((0\d)|(1[0-2]))(([0|1|2]\d)|3[0-1])\d{3}$)|(^[1-9]\d{5}[1-9]\d{3}((0\d)|(1[0-2]))(([0|1|2]\d)|3[0-1])((\d{4})|\d{3}[Xx])$)$/;
      console.log("进来了吗");
      if (idCardReg.test(this.pageForm.idcard) === false) {
        this.$toast.fail("身份证格式不合法!");
        this.pageForm.idcard = "";
        return;
      }
      // 获取性别
      if (+this.pageForm.idcard.slice(16, 17) % 2 == 0) {
        this.pageForm.sex = 2;
      } else {
        this.pageForm.sex = 1;
      }
      // 获取出生年月日
      this.pageForm.birthday =
        this.pageForm.idcard.substring(6, 10) +
        "-" +
        this.pageForm.idcard.substring(10, 12) +
        "-" +
        this.pageForm.idcard.substring(12, 14);
    },
    handlePopupClose() {
      var flag = false,
        ISFILL = false; // 是否填写
      for (let i = 0; i < this.questionnairelist.length; i++) {
        let res = this.questionnairelist[i];
        for (let k = 0; k < res.questionnaireitems.length; k++) {
          const element = res.questionnaireitems;
          // console.log(element[k], element[k].isFill);
          if (element[k].fillFlag == 1) {
            flag = true;
          } // 1必填 0非必填
          // 子题
          for (let j = 0; j < element[k].questionnaireitems.length; j++) {
            const elJ = element[k].questionnaireitems[j];
            // console.log(elJ, elJ.isFill);
            if (!elJ.isFill) {
              ISFILL = true;
            }
          }
          // console.log(element[k]);
        }
      }
      if (flag) {
        this.$dialog
          .alert({
            title: "提示",
            message: "请填写全部必填项",
          })
          .then(() => {
            // on close
          });
        return;
      } else if (ISFILL) {
        this.$dialog
          .alert({
            title: "提示",
            message: "问卷未填写完成，是否继续填写",
            confirmButtonText: "提 交",
            cancelButtonText: "继续填写",
            showCancelButton: true,
          })
          .then((res) => {
            this.showQuestionnaire = false;
            this.fillOutFlag = true; //  已完成填写
            return;
          })
          .catch((err) => {});
        return;
      } else {
        this.showQuestionnaire = false;
        this.fillOutFlag = true; //  已完成填写
      }
    },
    // 多选回调
    handlechecBox(item, num) {
      let result = "";
      if (item.optionitems) {
        const IS = item.optionitems.some((k) => {
          if (k.flag == 1 || !!k.flag) {
            k.flag = 1;
            result = k.selectvalue;
            return true;
          } else {
            return false;
          }
        });
        item.isFill = IS ? result : "";
      } else {
        item.isFill = item.flag == 1 ? item.selectvalue : "";
      }
      if (!item.isFill) {
        // 如果是必填 1 就把fillFlag改成0
        item.fillFlag = item.mustflag == 1 ? 1 : 0;
      } else {
        item.fillFlag = 0;
      }
    },
    // 输入框回调
    handleValue(res, item) {
      // 只需要有个值就行, isFill用来判断是否填写
      this.$nextTick(() => {
        if (item.optionitems.length > 0) {
          item.isFill = item.optionitems[0].selectvalue || "";
        } else {
          item.isFill = item.remark || "";
        }
      });
    },
    // 输入框回调
    handleUpdate(res, item, Flag) {
      this.$nextTick(() => {
        item.optionitems.forEach((k) => {
          item.isFill = k.remark;
        });

        //  是否为三段输入框做不同处理
        if (!Flag) {
          if (res.length == 3 && item.mustflag == 1) {
            item.fillFlag = 0;
          } else {
            item.fillFlag = 1;
          }
        } else {
          item.fillFlag = 0;
        }
      });
    },
    // 输入框回调
    handleInput(item) {
      item.isFill = item.remark;
      if (!item.isFill) {
        // 如果是必填 1 就把fillFlag改成0
        item.fillFlag = item.mustflag == 1 ? 1 : 0;
      } else {
        item.fillFlag = 0;
      }
    },
    // 单选回调
    handleRadioChange(item) {
      item.isFill = item.selectvalue;
      if (!item.isFill) {
        item.fillFlag = item.mustflag == 1 ? 1 : 0;
      } else {
        item.fillFlag = 0;
      }
    },
    // 问卷调查是否可见
    handleShowQ() {
      Sys_QuestionnaireForH5_ShowCode().then((res) => {
        //  1男 2女 3未知
        const Data = res.data.result.split("-");
        if (res.data.code == 200 && Data[0] === "0") {
          this.questionnaireFlag = false;
          return;
        }
        Data.length != 4
          ? (this.questionnaireFlag = false)
          : (this.questionnaireFlag = true);
        this.questionCode =
          this.pageForm.sex == 1
            ? Data[1]
            : this.pageForm.sex == 2
            ? Data[2]
            : Data[3];
      });
    },
    // 问卷调查点击回调
    handleShowQuestionnaire() {
      // 问卷
      if (this.questionnairelist && this.questionnairelist.length == 0) {
        let titlecode = this.questionCode;
        // 如果个人有code就用个人的
        if (this.personalflag == 1 && this.setmealObj.quecode) {
          titlecode = this.setmealObj.quecode;
        }
        if (!titlecode) return;
        questionnaire({ titlecode }).then((res) => {
          this.questionnairelist = res.data.result;
          this.questionnairelist.map((k) => {
            // 题
            k.questionnaireitems = k.questionnaireitems.map((item) => {
              // 子题
              if (item.questionnaireitems.length > 0) {
                item.questionnaireitems = item.questionnaireitems.map((u) => {
                  return { ...u, isFill: "", isFill: "", fillFlag: u.mustflag };
                });
              }
              return {
                ...item,
                isFill: "",
                fillFlag: item.mustflag,
              };
            });

            return { ...k, questionnaireitems: k.questionnaireitems };
          });
          console.log(this.questionnairelist);
          this.showQuestionnaire = true;
        });
      } else {
        this.showQuestionnaire = true;
      }
    },
    // 获取价格接口回调
    handleGetPriceItems() {
      let whereitems = [];
      let combinecodes = this.combineitems.map((k) => {
        return k.combinecode;
      });
      if (this.personalflag == 0) {
        whereitems.push({
          key: "personalflag",
          value: this.personalflag,
        });
        whereitems.push({
          key: "setmealcode",
          value: this.setmealcode,
        });
        whereitems.push({
          key: "combinecodes",
          value: combinecodes.join(","),
        });
      } else {
        whereitems.push({
          key: "regid",
          value: this.userData.regid,
        });
        whereitems.push({
          key: "personalflag",
          value: this.personalflag,
        });
        whereitems.push({
          key: "combinecodes",
          value: combinecodes.join(","),
        });
        whereitems.push({
          key: "companycode",
          value: this.userData.companycode,
        });
        whereitems.push({
          key: "batch",
          value: this.userData.batch,
        });
        whereitems.push({
          key: "groupcode",
          value: this.userData.groupcode,
        });
      }
      getListData({
        businesstype: "CostInfo",
        whereitems,
      }).then((res) => {
        if (!res.data.result) return;
        let data = res.data.result;
        this.checkPrice = data.checkPrice;
        this.personPrice = data.personPrice;
        this.quota = data.quota;
        this.totalPrice = data.totalPrice;
      });
    },
    // 点击选中体检人弹框
    handleCheckShowPerson() {
      // this.showPerson = true;
      this.$router.push({
        path: "/selectUser",
        query: {
          setmealcode: this.setmealcode,
          pageFrom: "reservaInfo",
          combineitems: encodeURIComponent(JSON.stringify(this.combineitems)),
        },
      });
    },
    // 获取列表数据回调
    handleGetUserList() {
      getListData({
        businesstype: "MyCheckPersonList",
        code: this.operatorcode,
        whereitems: [],
      }).then((res) => {
        if (!res.data.result) return;
        let index = res.data.result.filter((k) => {
          return k.id === this.checkUserId;
        })[0];
        if (index) {
          this.pageForm = index;
          switch (index.idtype || "01") {
            case "01":
              this.pageForm.idcardcn = "身份证";
              break;
            case "02":
              this.pageForm.idcardcn = "居民户口簿";
              break;
            case "03":
              this.pageForm.idcardcn = "护照";
              break;
            case "04":
              this.pageForm.idcardcn = "军官证";
              break;
            case "05":
              this.pageForm.idcardcn = "驾驶证";
              break;
            case "06":
              this.pageForm.idcardcn = "港澳居民来往内地通行证";
              break;
            case "07":
              this.pageForm.idcardcn = "台湾居民来往内地通行证";
              break;
            default:
              break;
          }
        }
      });
    },
    // 选中证件类型回调
    handleOnConfirmIdtype(value) {
      // this.pageForm.idtype = value;
      if (!value) return;
      switch (value) {
        case "身份证":
          this.pageForm.idtype = "01";
          this.pageForm.idcardcn = "身份证";
          break;
        case "居民户口簿":
          this.pageForm.idtype = "02";
          this.pageForm.idcardcn = "居民户口簿";
          break;
        case "护照":
          this.pageForm.idtype = "03";
          this.pageForm.idcardcn = "护照";
          break;
        case "军官证":
          this.pageForm.idtype = "04";
          this.pageForm.idcardcn = "军官证";
          break;
        case "驾驶证":
          this.pageForm.idtype = "05";
          this.pageForm.idcardcn = "驾驶证";
          break;
        case "港澳居民来往内地通行证":
          this.pageForm.idtype = "06";
          this.pageForm.idcardcn = "港澳居民来往内地通行证";
          break;
        case "台湾居民来往内地通行证":
          this.pageForm.idtype = "07";
          this.pageForm.idcardcn = "台湾居民来往内地通行证";
          break;
        default:
          break;
      }
      this.showPelsidtype = false;
    },
    // 提交订单回调
    handleSubmitOrder() {
      // 不允许为空
      if (this.personalflag == 0) {
        let temparr = ["name", "sex", "idcard", "telephone"];
        // 不允许为空
        for (let i = 0; i < temparr.length; i++) {
          if (this.pageForm.hasOwnProperty(temparr[i])) {
            if (this.pageForm[temparr[i]] === "") {
              this.$toast.fail("姓名,性别,身份证,手机号不允许为空!");
              return;
            }
          }
        }
      }
      if (!this.chooseDate) {
        this.$toast.fail("请选择检查日期!");
        return;
      }
      this.loading = true;
      // 组装数据
      let orderitem = {
        regid: this.personalflag == 1 ? this.userData.regid : "",
        orderid: this.EditOrderid || "",
        setmealcode: this.setmealObj.setmealcode || "",
        setmealname: this.setmealObj.setmealname || "",
        name: this.pageForm.name,
        sex: this.pageForm.sex,
        age: 0,
        ageunit: "岁",
        birthday: this.pageForm.birthday || "",
        marriage: this.pageForm.marriage || "",
        transport: this.pageForm.transport || "",
        telephone: this.pageForm.telephone || "",
        idtype: this.pageForm.idtype,
        idcard: this.pageForm.idcard || "",
        checkdate: this.chooseDate.title || "",
        personalflag: this.personalflag,
        companycode: this.personalflag == 1 ? this.userData.companycode : "",
        companyname: this.personalflag == 1 ? this.userData.companyname : "",
        batch: this.personalflag == 1 ? this.userData.batch : "",
        groupcode: this.personalflag == 1 ? this.userData.groupcode : "",
        totalprice: this.personPrice || 0,
        remark: this.personalflag == 1 ? this.userData.remark : "",
        operatorcode: this.operatorcode,
        setmealwarnmsg: this.setmealObj.setmealwarnmsg || "",
        setmealremind: this.setmealObj.setmealreminditems.join("<br>") || "",
        timeid: this.chooseDate.timeid,
        selecttimespan: this.chooseDate.selecttimespan,
        hiscode: this.pageForm.hiscode || "",
        healthcard: this.pageForm.healthcard || "",
      };
      this.setmealObj.combineitems = this.setmealObj.combineitems.map((k) => {
        return {
          ...k,
          addflag: 0,
        };
      });
      this.combineitems = this.combineitems.map((k) => {
        return {
          ...k,
          addflag: 1,
        };
      });
      let orderdetailitems = [
        ...this.setmealObj.combineitems,
        ...this.combineitems,
      ];
      // 当前问卷是否必填
      CheckQuestionMustInput({
        sex: orderitem.sex,
        companycode: orderitem.companycode,
        batch: orderitem.batch,
        groupcode: orderitem.groupcode,
      }).then((res) => {
        console.log(res);
        if (res.data.result && this.fillOutFlag != res.data.result) {
          console.log(this.fillOutFlag, res.data.result);
          this.$toast.fail("请填写问卷调查!");
          this.loading = false;
          return;
        }
        // 保存
        addCustomerOrder({
          orderitem,
          orderdetailitems,
        })
          .then((res) => {
            this.loading = false;
            if (res.data.code != 200) {
              this.$toast.fail(res.data.message);
              return;
            }
            this.$toast.success(res.data.message);
            localStorage.removeItem("delComCode");
            let data = res.data.result;
            localStorage.setItem("customercode", data.customercode); // 支付 orderid
            localStorage.setItem("orderid", data.orderid); // 支付 orderid
            localStorage.removeItem("EditOrderid"); // 修改订单 orderid
            saveAppoint({
              regiditems: [data.regid],
              checknoitems: [],
              selectdate: this.chooseDate.title,
              timeid: this.chooseDate.timeid,
            }).then((res) => {
              if (res.data.result && res.data.result.issuccess) {
                this.$dialog
                  .alert({
                    title: "提示",
                    message: "订单提交成功",
                    confirmButtonText: "查看订单",
                    confirmButtonColor: "#1989fa",
                  })
                  .then(() => {
                    // on confirm
                    this.$router.push({
                      path: "/orderConfirm",
                      query: { orderid: data.orderid },
                    });
                  })
                  .catch(() => {
                    // on cancel
                  });
              }
            });
          })
          .catch((err) => {
            this.loading = false;
          });
      });
    },
    // 点击确认选中日期回调
    handleCheckDateSubmit() {
      if (!this.chooseDate) {
        this.$toast.success("请先选中日期!");
        return;
      }
      if (this.setcompanymodel == 1) {
        if (!this.chooseTimes) {
          this.$toast.success("请先选中预约时段!");
          return;
        }
      }
      // this.chooseDate =
      //   this.calendarData.filter((k) => {
      //     return this.chooseDateTitle == k.titleday;
      //   })[0] || "";
      this.showPelsDate = false;
    },
    // 点击选择日期效果
    handleCheckChooseDate(item) {
      if (!item) return;
      if (item.status != 1) {
        this.$toast.fail("当前日期不可预约!");
        return;
      }
      this.chooseDate = item;
      console.log(this.chooseDate, "this.chooseDate");
      this.chooseDateTitle = item.titleday;
    },
    handleCheckChooseTimes(item) {
      this.chooseTimes = item;
      this.chooseDate.timeid = item.timeid;
      console.log(this.chooseDate.timeid);
    },
    // 点击选择日期回调
    handleCheckDateShow() {
      let data = null;
      // personflag 0-个人  1-单位
      if (this.personalflag == 0) {
        TimeStaticForPerson({ setmealcode: this.setmealcode })
          .then((res) => {
            this.calendarData = res.data.result.dateitems;
            this.calendarSource = JSON.parse(JSON.stringify(this.calendarData));
            this.setcompanymodel = res.data.result.setcompanymodel;
            this.showPelsDate = true;
          })
          .catch(() => {
            this.$toast.success("没有符合的预约日期!");
          });
      } else {
        data = {
          personflag: this.personalflag,
          companycode: this.userData.companycode,
          batch: this.userData.batch,
        };
        timeStatic(data)
          .then((res) => {
            this.calendarData = res.data.result.dateitems;
            this.calendarSource = JSON.parse(JSON.stringify(this.calendarData));
            this.setcompanymodel = res.data.result.setcompanymodel;
            this.showPelsDate = true;
          })
          .catch(() => {
            this.$toast.success("没有符合的预约日期!");
          });
      }
    },
    // 改变是否只显示可预约
    handleChangeIsReserv(flag) {
      if (flag) {
        this.calendarData = this.calendarSource.filter((k) => {
          return k.status == 1;
        });
      } else {
        this.calendarData = tJSON.parse(JSON.stringify(this.calendarSource));
      }
      // status 1-可预约
      console.log(flag);
    },
    // 选择生日回调
    handleChangeonBirthday(time) {
      this.pageForm.birthday = this.formatDate(+time);
      this.showPicker = false;
    },
    formatDate(value) {
      // 时间戳转换日期格式方法
      if (value == null) {
        return "";
      } else {
        const date = new Date(value);
        const y = date.getFullYear(); // 年
        let MM = date.getMonth() + 1; // 月
        MM = MM < 10 ? "0" + MM : MM;
        let d = date.getDate(); // 日
        d = d < 10 ? "0" + d : d;
        return y + "-" + MM + "-" + d;
      }
    },
  },

  watch: {},
};
</script>
<style lang='scss' scoped>
/deep/.el-checkbox {
  white-space: normal !important;
}
.reservaInfo {
