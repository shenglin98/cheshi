            <div class="text">检查日期</div>
          </div>
          <div class="content" v-if="chooseDate">
            {{ chooseDate.titleday || "" }}
            <!-- {{
              (this.setcompanymodel == 1 &&
                this.chooseTimes &&
                this.chooseTimes.contentkey) ||
              ""
            }} -->
