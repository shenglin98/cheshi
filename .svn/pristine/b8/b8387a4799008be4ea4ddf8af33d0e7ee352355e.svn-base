<template>
  <div class="selectUser">
    <!-- 主体内容 -->
    <div class="mainbody">
      <!-- 列表主页 -->
      <div class="listbox" v-if="pageStatus == 'list'">
        <!-- 人员列表 -->
        <div class="userlist">
          <!-- 人员项 -->
          <div
            class="useritem"
            v-for="item in userList"
            :key="item.id"
            :class="checkUser && checkUser.id == item.id ? 'checkbg' : ''"
            @click="handleCheckUser(item)"
          >
            <div class="itemleft">
              <div class="usericonbox">
                <van-icon class="usericon" name="manager-o" />
              </div>
              <div class="itemcontent">
                <div class="itemtop">
                  <div class="name">{{ item.name }}</div>
                  <div class="sex">
                    {{ item.sex == 1 ? "男" : item.sex == 2 ? "女" : "未知" }}
                  </div>
                  <div class="phone">{{ item.telephone }}</div>
                  <div class="marriage">{{ item.marriage }}</div>
                </div>
                <div class="idcard">{{ item.idcard }}</div>
              </div>
            </div>
            <div class="itemright">
              <van-icon name="edit" @click="handleItemEdit(item)" />
              <van-icon name="delete-o" @click="handleItemDel(item)" />
            </div>
          </div>
        </div>
        <!-- 底部按钮组 -->
        <div class="btn_bom">
          <van-button round size="small" type="primary" @click="handleAddUser"
            >新 增</van-button
          >
          <van-button round size="small" type="info" @click="handleSelectUser"
            >确 认</van-button
          >
        </div>
      </div>
      <!-- 新增编辑页 -->
      <div class="details" v-else>
        <van-form class="pageform">
          <!-- 姓名 -->
          <div class="name_box">
            <van-field
              v-model="pageForm.name"
              name="姓名"
              label="姓名"
              placeholder="（必填）请输入姓名"
              :rules="[{ required: true, message: '请填写姓名' }]"
            />
          </div>
          <!-- 证件类型 -->
          <van-field
            readonly
            clickable
            name="picker"
            :value="pageForm.idcardcn"
            label="证件类型"
            placeholder="点击选择证件类型"
            @click="showPelsidtype = true"
          />
          <!-- 身份证 -->
          <van-field
            v-model="pageForm.idcard"
            name="身份证"
            label="身份证"
            placeholder="身份证"
            :rules="[{ required: true, message: '请填写身份证' }]"
            @blur="handleCheckIdcard"
          />
          <!-- 性别 -->
          <van-field name="radio" label="性别">
            <template #input>
              <van-radio-group v-model="pageForm.sex" direction="horizontal">
                <van-radio :name="1">男</van-radio>
                <van-radio :name="2">女</van-radio>
              </van-radio-group>
            </template>
          </van-field>
          <!-- 生日 -->
          <van-field
            readonly
            clickable
            name="date"
            :value="pageForm.birthday"
            label="生日"
            placeholder="请选择生日"
            @click="showPicker = true"
          />
          <van-popup
            v-model="showPicker"
            position="bottom"
            :style="{ height: '45%' }"
          >
            <van-datetime-picker
              type="date"
              item-height="120px"
              @confirm="handleChangeonBirthday"
              @cancel="showPicker = false"
              v-model="relWkibedat"
              :min-date="minDate"
              :max-date="maxDate"
            />
          </van-popup>
          <!-- 婚姻状况 -->
          <van-field name="radio" label="婚姻状况">
            <template #input>
              <van-radio-group
                v-model="pageForm.marriage"
                direction="horizontal"
              >
                <van-radio name="未婚">未婚</van-radio>
                <van-radio name="已婚">已婚</van-radio>
              </van-radio-group>
            </template>
          </van-field>
          <!-- 手机号 -->
          <van-field
            v-model="pageForm.telephone"
            name="手机号"
            label="手机号"
            placeholder="手机号"
          />
          <!-- 身高 -->
          <van-field
            v-model="pageForm.height"
            name="height"
            label="身高"
            placeholder="cm"
          />
          <!-- 体重 -->
          <van-field
            v-model="pageForm.weight"
            name="width"
            label="体重"
            placeholder="kg"
          />
        </van-form>
        <!-- 证件类型 -->
        <van-popup
          v-model="showPelsidtype"
          :style="{ height: '48%' }"
          position="bottom"
        >
          <van-picker
            show-toolbar
            item-height="120px"
            :columns="idtypeItems"
            @confirm="handleOnConfirmIdtype"
            @cancel="showPelsidtype = false"
          />
        </van-popup>
        <!-- 保存按钮回调 -->
        <div class="btn_d">
          <van-button
            round
            size="small"
            type="primary"
            @click="handleReturnList"
            >返 回</van-button
          >
          <van-button
            round
            size="small"
            type="info"
            @click="handleSaveUserInfo"
            :loading="btnLoading"
            >保 存</van-button
          >
        </div>
      </div>
    </div>
  </div>
</template>
<script>
import { addOrUpdateMyFamily } from "@/api/unit.js";
import { getListData } from "@/api/reservation.js";

export default {
  name: "",

  components: {},

  data() {
    return {
      pageFrom: "",
      operatorcode: "",
      pageStatus: "list", // list details
      userList: [],
      btnLoading: false,
      pageForm: {
        id: "",
        name: "",
        sex: 0,
        birthday: "",
        marriage: "",
        telephone: "",
        idcard: "",
        idtype: "01",
        idcardcn: "身份证",
        relation: "",
        delflag: 0,
        operatorcode: "",
        hiscode: "",
        healthcard: "",
        height: "",
        width: "",
      },
      checkUser: null,
      showPicker: false,
      showPelsidtype: false,
      relWkibedat: new Date("2000/01/01"),
      minDate: new Date(1900, 0, 1),
      maxDate: new Date(
        new Date(+new Date() + 8 * 3600 * 1000)
          .toJSON()
          .substr(0, 10)
          .replace("T", " ")
      ),
      idtypeItems: [
        "身份证",
        "居民户口簿",
        "护照",
        "军官证",
        "驾驶证",
        "港澳居民来往内地通行证",
        "台湾居民来往内地通行证",
      ],
      query: null,
      setmealcode: "",
      combineitems: [],
      isUser: false, //是否从个人页面跳转过来的
    };
  },

  mounted() {
    this.pageFrom = this.$route.query.pageFrom || "";
    this.isUser = this.$route.query.isUser; // 个人页面跳转过来的
    this.query = this.$route.query;
    if (!this.pageFrom && !this.$route.query.isUser) {
      this.$toast.fail("获取查询信息失败!");
      setTimeout(() => {
        this.$router.push("/");
      }, 800);
      return;
    }
    this.operatorcode = localStorage.getItem("operatorcode") || "";
    this.pageForm.operatorcode = localStorage.getItem("operatorcode") || "";
    if (!this.pageForm.operatorcode) {
      this.$router.push("/");
      return false;
    }
    if (this.pageFrom == "reservaInfo") {
      let data = this.$route.query || undefined;
      this.setmealcode = data.setmealcode;
      this.combineitems = JSON.parse(decodeURIComponent(data.combineitems));
    }
    this.handleGetUserList();
  },

  methods: {
    // 失焦校验身份证
    handleCheckIdcard() {
      let idCardReg =
        /^(^[1-9]\d{7}((0\d)|(1[0-2]))(([0|1|2]\d)|3[0-1])\d{3}$)|(^[1-9]\d{5}[1-9]\d{3}((0\d)|(1[0-2]))(([0|1|2]\d)|3[0-1])((\d{4})|\d{3}[Xx])$)$/;
      console.log("进来了吗");
      if (idCardReg.test(this.pageForm.idcard) === false) {
        this.$toast.fail("身份证格式不合法!");
        this.pageForm.idcard = "";
        return;
      }
      // 获取性别
      if (+this.pageForm.idcard.slice(16, 17) % 2 == 0) {
        this.pageForm.sex = 2;
      } else {
        this.pageForm.sex = 1;
      }
      // 获取出生年月日
      this.pageForm.birthday =
        this.pageForm.idcard.substring(6, 10) +
        "-" +
        this.pageForm.idcard.substring(10, 12) +
        "-" +
        this.pageForm.idcard.substring(12, 14);
    },
    // 选中人员点击确认提交回调
    handleSelectUser() {
      if (!this.checkUser) {
        this.$toast.fail("请先选中人员");
        return;
      }
      this.query.checkUser = this.checkUser.id;
      if (this.pageFrom == "reservaInfo") {
        this.$router.push({
          path: `/${this.pageFrom}`,
          query: {
            setmealcode: this.setmealcode,
            checkUser: this.checkUser.id,
            combineitems: encodeURIComponent(JSON.stringify(this.combineitems)),
          },
          // query: {  },
        });
      } else {
        this.$router.push({
          path: `/${this.pageFrom}`,
          query: this.query,
          // query: { checkUser: this.checkUser.id },
        });
      }
    },
    // 点击选中当前人员
    handleCheckUser(item) {
      if (!item) return;
      this.checkUser = JSON.parse(JSON.stringify(item));
    },
    // 获取列表数据回调
    handleGetUserList() {
      getListData({
        businesstype: "MyCheckPersonList",
        code: this.operatorcode,
        whereitems: [],
      }).then((res) => {
        if (!res.data.result) {
          this.userList = [];
          return;
        }
        this.userList = res.data.result;
      });
    },
    // 用户列表编辑回调
    handleItemEdit(item) {
      this.checkUser = JSON.parse(JSON.stringify(item));
      if (!this.checkUser) {
        this.$toast.fail("请先选中人员");
        return;
      }
      this.pageForm = this.checkUser;
      switch (this.pageForm.idtype) {
        case "01":
          this.pageForm.idcardcn = "身份证";
          break;
        case "02":
          this.pageForm.idcardcn = "居民户口簿";
          break;
        case "03":
          this.pageForm.idcardcn = "护照";
          break;
        case "04":
          this.pageForm.idcardcn = "军官证";
          break;
        case "05":
          this.pageForm.idcardcn = "驾驶证";
          break;
        case "06":
          this.pageForm.idcardcn = "港澳居民来往内地通行证";
          break;
        case "07":
          this.pageForm.idcardcn = "台湾居民来往内地通行证";
          break;
        default:
          break;
      }
      this.pageStatus = "details";
    },
    // 用户列表删除回调
    handleItemDel(item) {
      this.checkUser = JSON.parse(JSON.stringify(item));
      if (!this.checkUser) {
        this.$toast.fail("请先选中人员");
        return;
      }
      this.$dialog
        .confirm({
          title: "提示",
          message: `确认删除当前用户? ${this.checkUser.name}`,
        })
        .then(() => {
          // on confirm
          this.checkUser.delflag = 1; // 状态改为一则为删除
          addOrUpdateMyFamily(this.checkUser).then((res) => {
            this.$toast.success(res.data.message);
            this.pageStatus = "list";
            this.handleResetPageForm();
            this.handleGetUserList();
          });
        })
        .catch(() => {
          // on cancel
        });
    },
    // 点击返回列表页
    handleReturnList() {
      this.pageStatus = "list";
      this.handleResetPageForm();
      this.handleGetUserList();
    },
    // 点击保存用户回调
    handleSaveUserInfo() {
      let temparr = ["name", "sex", "idcard", "telephone"];
      // 不允许为空
      for (let i = 0; i < temparr.length; i++) {
        if (this.pageForm.hasOwnProperty(temparr[i])) {
          console.log(temparr[i], "temparr[i]");
          if (this.pageForm[temparr[i]] === "") {
            this.$toast.fail("姓名,性别,身份证,手机号不允许为空!");
            return;
          }
        }
      }
      this.btnLoading = true;
      addOrUpdateMyFamily(this.pageForm)
        .then((res) => {
          this.btnLoading = false;
          this.$toast.success(res.data.message);
          this.pageStatus = "list";
          this.handleResetPageForm();
          this.handleGetUserList();
        })
        .catch(() => {
          this.btnLoading = false;
        });
    },
    // 选择生日回调
    handleChangeonBirthday(time) {
      this.pageForm.birthday = this.formatDate(+time);
      this.showPicker = false;
    },
    // 选中证件类型回调
    handleOnConfirmIdtype(value) {
      // this.pageForm.idtype = value;
      if (!value) return;
      switch (value) {
        case "身份证":
          this.pageForm.idtype = "01";
          this.pageForm.idcardcn = "身份证";
          break;
        case "居民户口簿":
          this.pageForm.idtype = "02";
          this.pageForm.idcardcn = "居民户口簿";
          break;
        case "护照":
          this.pageForm.idtype = "03";
          this.pageForm.idcardcn = "护照";
          break;
        case "军官证":
          this.pageForm.idtype = "04";
          this.pageForm.idcardcn = "军官证";
          break;
        case "驾驶证":
          this.pageForm.idtype = "05";
          this.pageForm.idcardcn = "驾驶证";
          break;
        case "港澳居民来往内地通行证":
          this.pageForm.idtype = "06";
          this.pageForm.idcardcn = "港澳居民来往内地通行证";
          break;
        case "台湾居民来往内地通行证":
          this.pageForm.idtype = "07";
          this.pageForm.idcardcn = "台湾居民来往内地通行证";
          break;
        default:
          break;
      }
      this.showPelsidtype = false;
    },
    // 重置表单
    handleResetPageForm() {
      this.pageForm = {
        id: "",
        name: "",
        sex: 0,
        birthday: "",
        marriage: "",
        telephone: "",
        idcard: "",
        idtype: "01",
        idcardcn: "身份证",
        relation: "",
        delflag: 0,
        operatorcode: this.operatorcode,
      };
      this.checkUser = null;
    },
    formatDate(value) {
      // 时间戳转换日期格式方法
      if (value == null) {
        return "";
      } else {
        const date = new Date(value);
        const y = date.getFullYear(); // 年
        let MM = date.getMonth() + 1; // 月
        MM = MM < 10 ? "0" + MM : MM;
        let d = date.getDate(); // 日
        d = d < 10 ? "0" + d : d;
        return y + "-" + MM + "-" + d;
      }
    },
    // 新增人员回调
    handleAddUser() {
      this.pageStatus = "details";
    },
  },

  watch: {},

  computed: {},
};
</script>
<style lang='scss' scoped>
.selectUser {
  height: calc(100vh - 94px);
  background-color: #f2f2f2;
  box-sizing: border-box;
  padding: 5px;
  .mainbody {
    width: 100%;
    height: 100%;
    overflow-y: auto;
    box-sizing: border-box;
    background-color: #fff;
    border-radius: 6px;
    .listbox {
      width: 100%;
      height: 100%;
      .userlist {
        width: 100%;
        height: 88%;
        box-sizing: border-box;
        padding: 4px;
        overflow-y: auto;
        .checkbg {
          border: 1px solid #1989fa !important;
        }
        .useritem {
          height: 65px;
          box-sizing: border-box;
          padding: 6px;
          display: flex;
          border: 1px solid #ebebeb;
          border-radius: 6px;
          margin-bottom: 8px;
          .itemleft {
            width: 88%;
            display: flex;
            .usericonbox {
              margin: 0 8px 0 0;
              display: flex;
              justify-content: center;
              align-items: center;
              .usericon {
                font-size: 26px;
              }
            }
            .itemcontent {
              display: flex;
              flex-direction: column;
              font-size: 14px;
              justify-content: space-around;
              .itemtop {
                display: flex;
                div {
                  margin-right: 15px;
                }
              }
            }
          }
          .itemright {
            width: 10%;
            display: flex;
            flex-direction: column;
            font-size: 18px;
            align-items: center;
            justify-content: space-around;
          }
        }
      }
      .btn_bom {
        width: 100%;
        margin-top: 14px;
        text-align: center;
        .van-button {
          width: 30%;
          margin-right: 10px;
        }
      }
    }
    .details {
      width: 100%;
      height: 100%;
      .btn_d {
        width: 100%;
        margin-top: 50px;
        text-align: center;
        .van-button {
          width: 30%;
          margin-right: 10px;
        }
      }
    }
  }
}
</style>