  width: 100%;
  height: calc(100% - 95px);
  box-sizing: border-box;
  padding-bottom: 50px;
  .big {
    height: 100%;
    .btn_box {
      height: 40px;
      display: flex;
      justify-content: center;
      align-items: center;
    }
  }
  .pdfCotainer {
    width: 100%;
    height: 100%;
  }
  //   #demo {
  //     width: 100%;
  //     height: 100%;
  //   }
}
.loading {
  width: 100%;
  height: 100%;
  /* background: red; */
  position: fixed;
  z-index: 10;
  left: 0;
  top: 0;
}

.loadingone {
  height: 100%;
}
.mask {
  width: 100%;
  height: 100vh;
  background-color: #666666;
  padding-top: 30%;
  z-index: 999;
}
.mask .tips {
  color: #ffffff;
  text-align: center;
  margin-bottom: 20px;
  font-size: 16px;
  font-weight: 600;
}
.button {
  width: 90%;
  padding: 5%;
}
</style>
  