        width: 18px;
        height: 18px;
        margin-left: 8px;
      }
    }
  }
  .calendar {
    height: 140px;
    background-color: #fff;
    margin-top: 5px;
    padding: 8px;
    .calendar_box {
      .van-notice-bar {
        height: 22px;
        padding: 0 8px;
      }
    }
    .calendar_list::-webkit-scrollbar {
      display: none;
    }
    .calendar_list {
      height: 80px;
      margin-top: 8px;
      overflow-x: auto;

      .calendar_roll {
        height: 100%;
        display: flex;
        .calendar_item {
          flex-shrink: 0;
          background-color: #f2f2f2;
          border-radius: 4px;
          height: 100%;
          width: 70px !important;
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
          margin-right: 8px;
