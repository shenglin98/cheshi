            color: #27a7e0;
          }
        }
        .calendar_bgl {
          background-color: #409eff !important;
          .week,
          .date,
          .today,
          .is_reserv {
            color: #fff !important;
          }
        }
      }
    }
    .calendar_title {
      font-size: 16px;
      font-weight: 600;
      padding-bottom: 8px;
      border-bottom: 1px solid #d8d8d8;
    }
  }
  .setmeal_mess {
    margin-top: 5px;

    .van-tab__pane {
      background-color: #fff;
      padding: 20px;
    }
    .setmeal_title {
      height: 32px;
      background-color: #f2f2f2;
      display: flex;
      font-size: 16px;
      font-weight: 600;
      align-items: center;
      justify-content: center;
    }
    .setmeal_box {
      .setmeal_name {
        height: 32px;
        background-color: #fff;
        display: flex;
        font-size: 14px;
        font-weight: 600;
        align-items: center;
      }
      .setmeal_remark {
        min-height: 32px;
        background-color: #f2f2f2;
